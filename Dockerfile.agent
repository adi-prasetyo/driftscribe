# ---- Stage 1: build the Svelte+Vite operator UI into agent/static/ ----------
# vite.config.ts outputs to ../agent/static (i.e. /build/agent/static here).
# `npm ci` requires the committed frontend/package-lock.json (.gitignore
# re-includes it). The Python stage copies ONLY the built output across, so node
# never ships in the runtime image.
FROM node:24-slim AS frontend
WORKDIR /build
COPY frontend/ ./frontend/
RUN cd frontend && npm ci && npm run build

# ---- Stage 2: the Python coordinator runtime --------------------------------
FROM python:3.12-slim
WORKDIR /app
RUN pip install --no-cache-dir uv
# Editable install needs the source tree present at install time. Copy
# pyproject.toml + source first; the install layer busts on source changes,
# but the hackathon doesn't need fancy two-stage layer caching.
COPY pyproject.toml ./
COPY agent/ ./agent/
# Built SPA bundle from the frontend stage. MUST come after `COPY agent/` so it
# is authoritative (and .dockerignore excludes agent/static/ so no stale local
# copy leaks in via `COPY agent/`). Served by StaticFiles at /static; the shell
# route resolves hashed names from agent/static/.vite/manifest.json.
COPY --from=frontend /build/agent/static ./agent/static
COPY checker/ ./checker/
COPY driftscribe_lib/ ./driftscribe_lib/
RUN uv pip install --system -e .
# Preserve the contract-relative path so DOCS_ROOT=/contract resolves
# `demo/docs/runbook.md` to `/contract/demo/docs/runbook.md`.
COPY demo/ /contract/demo/
# Workload manifests (Phase 17+) are loaded at runtime by
# agent/workloads/registry.py via Path(__file__).parents[2]/"workloads",
# which resolves to /app/workloads inside the container. Not a Python
# package (pyproject `[tool.setuptools] packages` doesn't include it),
# so it must be copied as plain data after the editable install.
COPY workloads/ ./workloads/
# The `tools` package (Phase D5): agent/fanout.py imports
# driftscribe_lib.iac_editor_policy, which does
# `from tools.iac_static_gate import ...` (the AGENT-mode static-gate policy
# constants — the single source of truth shared with CI + the tofu-editor
# worker). `tools` is NOT a setuptools package (see pyproject
# [tool.setuptools] packages), so the editable install above does NOT expose
# it; copy it as a PACKAGE and put /app on PYTHONPATH so the import resolves
# (mirrors workers/tofu_editor/Dockerfile). iac_static_gate imports ONLY
# driftscribe_lib.iac_hcl (already installed) + stdlib, so no other tools/*.py
# is needed. Pre-D5 the coordinator never imported iac_editor_policy (the
# single-agent open_infra_pr_tool defers all validation to the worker), which
# is why this COPY wasn't needed until the fan-out barrier landed.
COPY tools/__init__.py ./tools/__init__.py
COPY tools/iac_static_gate.py ./tools/iac_static_gate.py
ENV PYTHONPATH=/app
ENV PORT=8080
ENV DOCS_ROOT=/contract
ENV CONTRACT_PATH=/contract/demo/ops-contract.yaml
# Shell form so $PORT expands at runtime. Cloud Run injects PORT and expects
# the container to listen on its chosen value; hardcoding --port 8080 would
# break health checks the moment Cloud Run picked a different port.
CMD ["sh", "-c", "uvicorn agent.main:app --host 0.0.0.0 --port ${PORT:-8080}"]

.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.env
.env.local
*.egg-info/
dist/
build/
.DS_Store
*:Zone.Identifier

# Node (tests/e2e/ui/ Playwright suite)
node_modules/
package-lock.json
# frontend/ uses `npm ci`, which REQUIRES a committed lockfile — re-include it.
!frontend/package-lock.json
playwright-report/
test-results/

# Frontend build output (Svelte+Vite → agent/static/). Built in Docker/CI and
# locally for the smoke; never committed.
agent/static/

# Local-only operator notes (gcloud account, billing, secrets recipes — never commit)
.claude/

# Git worktrees (isolated workspaces for feature work)
.worktrees/

# OpenTofu / Terraform (iac/) — plugin cache + state/plan artifacts must never
# be committed. The lockfile (iac/.terraform.lock.hcl) is intentionally tracked
# and is NOT matched by `.terraform/`.
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
